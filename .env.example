# Quant V6 — required environment variables.
# Copy to `.env` and fill in real values. Never commit `.env` to source control.

# --- Telegram alerter (src/utils/telegram_alerter.py) ---
# Bot token from @BotFather. Comma-separate multiple chat IDs to broadcast.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# --- Google Gemini sentiment LLM (src/models/quant_agent_arbitrator.py) ---
# API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional override; defaults to "gemini-3.5-flash" if unset.
GEMINI_MODEL=gemini-3.5-flash
